---
import "../styles/global.css";

const {
  title = "Syndication Manifest",
  description = "Predictable discovery for public feeds."
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={Astro.url} />
    <link rel="icon" type="image/png" href="/favicon.png" sizes="194x194" />
    <link rel="alternate" type="application/rss+xml" title="Syndication Manifest Entries" href="/feed.xml" />
    <link rel="alternate" type="application/rss+xml" title="Syndication Manifest Entries: Full Content" href="/feed-full.xml" />
    <title>{title}</title>
    <style is:inline>
      .skip-nav {
        background: #222521;
        color: #fffefa;
        left: 16px;
        position: fixed;
        top: 12px;
        transform: translateY(-160%);
        z-index: 50;
      }

      .skip-nav:focus {
        transform: translateY(0);
      }
    </style>
  </head>
  <body>
    <a class="skip-nav" href="#main">Skip to content</a>
    <div class="site-shell">
      <header class="site-header">
        <nav class="nav" aria-label="Primary">
          <a class="brand" href="/">
            <span class="brand-mark">ws</span>
            <span>Syndication Manifest</span>
          </a>
          <div class="nav-links">
            <a href="/entries/">Entries</a>
            <a href="/examples/">Examples</a>
            <a href="/spec/0.1/">Spec</a>
          </div>
        </nav>
      </header>
      <slot />
      <footer class="site-footer">
        <p>Predictable discovery for public feeds.</p>
        <nav class="footer-links" aria-label="Manifest links">
          <a href="/.well-known/syndication">Manifest</a>
        </nav>
      </footer>
    </div>
  </body>
</html>
